# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (both Prisma and raw MongoClient use this)
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/axigrade?retryWrites=true&w=majority"

# ── Auth (REQUIRED — app will crash on startup if missing) ────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET="CHANGE_ME_64_char_hex_string"

# ── Cloudinary (image & video reference uploads) ──────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ── Gemini (scene-modify) ─────────────────────────────────────────────────────
GEMINI_API_KEY="your_gemini_api_key"

# ── xAI / Grok ────────────────────────────────────────────────────────────────
# NOTE: xAI keys are user-supplied at runtime via the UI — NOT stored here.
# Users enter their own key in the Architect / Visual Hook key panel each session.

# ── Node environment ──────────────────────────────────────────────────────────
NODE_ENV="development"

# ── Optional: upgrade rate limiting to Redis for multi-instance production ────
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your_token"
